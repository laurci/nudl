{
	"$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
	"name": "nudl",
	"scopeName": "source.nudl",
	"patterns": [
		{ "include": "#comments" },
		{ "include": "#attributes" },
		{ "include": "#format-strings" },
		{ "include": "#strings" },
		{ "include": "#char-literals" },
		{ "include": "#labels" },
		{ "include": "#numbers" },
		{ "include": "#comptime-splice" },
		{ "include": "#import" },
		{ "include": "#declarations" },
		{ "include": "#constants" },
		{ "include": "#self-keywords" },
		{ "include": "#keywords" },
		{ "include": "#built-in-types" },
		{ "include": "#operators" },
		{ "include": "#function-call" },
		{ "include": "#type-names" }
	],
	"repository": {
		"comments": {
			"patterns": [
				{
					"name": "comment.line.double-slash.nudl",
					"match": "//.*$"
				},
				{
					"name": "comment.block.nudl",
					"begin": "/\\*",
					"end": "\\*/",
					"patterns": [
						{ "include": "#block-comment-nested" }
					]
				}
			]
		},
		"block-comment-nested": {
			"name": "comment.block.nudl",
			"begin": "/\\*",
			"end": "\\*/",
			"patterns": [
				{ "include": "#block-comment-nested" }
			]
		},
		"attributes": {
			"name": "meta.attribute.nudl",
			"begin": "#\\[",
			"end": "\\]",
			"beginCaptures": {
				"0": { "name": "punctuation.definition.attribute.begin.nudl" }
			},
			"endCaptures": {
				"0": { "name": "punctuation.definition.attribute.end.nudl" }
			},
			"patterns": [
				{ "include": "#strings" },
				{ "include": "#numbers" },
				{ "include": "#constants" },
				{
					"name": "entity.other.attribute-name.nudl",
					"match": "\\b[a-zA-Z_][a-zA-Z0-9_]*\\b"
				}
			]
		},
		"format-strings": {
			"name": "string.interpolated.nudl",
			"begin": "f\"",
			"end": "\"",
			"beginCaptures": {
				"0": { "name": "punctuation.definition.string.begin.nudl" }
			},
			"endCaptures": {
				"0": { "name": "punctuation.definition.string.end.nudl" }
			},
			"patterns": [
				{ "include": "#escape-sequences" },
				{
					"name": "constant.character.escape.nudl",
					"match": "\\{\\{|\\}\\}"
				},
				{
					"name": "meta.interpolation.nudl",
					"begin": "\\{",
					"end": "\\}",
					"beginCaptures": {
						"0": { "name": "punctuation.section.interpolation.begin.nudl" }
					},
					"endCaptures": {
						"0": { "name": "punctuation.section.interpolation.end.nudl" }
					},
					"patterns": [
						{ "include": "source.nudl" }
					]
				}
			]
		},
		"strings": {
			"name": "string.quoted.double.nudl",
			"begin": "\"",
			"end": "\"",
			"beginCaptures": {
				"0": { "name": "punctuation.definition.string.begin.nudl" }
			},
			"endCaptures": {
				"0": { "name": "punctuation.definition.string.end.nudl" }
			},
			"patterns": [
				{ "include": "#escape-sequences" }
			]
		},
		"char-literals": {
			"name": "string.quoted.single.nudl",
			"match": "'(?:[^'\\\\]|\\\\(?:[nrt0\\\\'\"]|x[0-9a-fA-F]{2}|u\\{[0-9a-fA-F]{1,6}\\}))'",
			"captures": {
				"0": { "name": "string.quoted.single.nudl" }
			}
		},
		"escape-sequences": {
			"name": "constant.character.escape.nudl",
			"match": "\\\\(?:[nrt0\\\\\"']|x[0-9a-fA-F]{2}|u\\{[0-9a-fA-F]{1,6}\\})"
		},
		"labels": {
			"patterns": [
				{
					"comment": "Label definition: 'name:",
					"match": "'([a-zA-Z_][a-zA-Z0-9_]*)\\s*:",
					"captures": {
						"1": { "name": "entity.name.label.nudl" }
					}
				},
				{
					"comment": "Label reference: break 'name, continue 'name",
					"match": "(?<=\\bbreak\\s|\\bcontinue\\s)\\s*'([a-zA-Z_][a-zA-Z0-9_]*)",
					"captures": {
						"1": { "name": "entity.name.label.nudl" }
					}
				}
			]
		},
		"numbers": {
			"patterns": [
				{
					"name": "constant.numeric.hex.nudl",
					"match": "\\b0x[0-9a-fA-F][0-9a-fA-F_]*(?:i8|i16|i32|i64|u8|u16|u32|u64)?\\b"
				},
				{
					"name": "constant.numeric.octal.nudl",
					"match": "\\b0o[0-7][0-7_]*(?:i8|i16|i32|i64|u8|u16|u32|u64)?\\b"
				},
				{
					"name": "constant.numeric.binary.nudl",
					"match": "\\b0b[01][01_]*(?:i8|i16|i32|i64|u8|u16|u32|u64)?\\b"
				},
				{
					"name": "constant.numeric.float.nudl",
					"match": "\\b[0-9][0-9_]*(?:\\.[0-9][0-9_]*)?(?:[eE][+-]?[0-9][0-9_]*)(?:f32|f64)?\\b"
				},
				{
					"name": "constant.numeric.float.nudl",
					"match": "\\b[0-9][0-9_]*\\.[0-9][0-9_]*(?:f32|f64)?\\b"
				},
				{
					"name": "constant.numeric.float.nudl",
					"match": "\\b[0-9][0-9_]*(?:f32|f64)\\b"
				},
				{
					"name": "constant.numeric.decimal.nudl",
					"match": "\\b[0-9][0-9_]*(?:i8|i16|i32|i64|u8|u16|u32|u64)?\\b"
				}
			]
		},
		"comptime-splice": {
			"name": "meta.splice.nudl",
			"begin": "\\$\\{",
			"end": "\\}",
			"beginCaptures": {
				"0": { "name": "punctuation.definition.splice.begin.nudl" }
			},
			"endCaptures": {
				"0": { "name": "punctuation.definition.splice.end.nudl" }
			},
			"patterns": [
				{ "include": "source.nudl" }
			]
		},
		"import": {
			"match": "\\b(import)\\s+([a-zA-Z_][a-zA-Z0-9_]*(?:::[a-zA-Z_][a-zA-Z0-9_]*)*(?:::\\*)?)",
			"captures": {
				"1": { "name": "keyword.control.import.nudl" },
				"2": { "name": "entity.name.namespace.nudl" }
			}
		},
		"declarations": {
			"patterns": [
				{
					"comment": "Function declaration",
					"match": "\\b(fn)\\s+([a-zA-Z_][a-zA-Z0-9_]*)",
					"captures": {
						"1": { "name": "keyword.other.fn.nudl" },
						"2": { "name": "entity.name.function.nudl" }
					}
				},
				{
					"comment": "Struct declaration",
					"match": "\\b(struct)\\s+([a-zA-Z_][a-zA-Z0-9_]*)",
					"captures": {
						"1": { "name": "keyword.other.struct.nudl" },
						"2": { "name": "entity.name.type.struct.nudl" }
					}
				},
				{
					"comment": "Enum declaration",
					"match": "\\b(enum)\\s+([a-zA-Z_][a-zA-Z0-9_]*)",
					"captures": {
						"1": { "name": "keyword.other.enum.nudl" },
						"2": { "name": "entity.name.type.enum.nudl" }
					}
				},
				{
					"comment": "Interface declaration",
					"match": "\\b(interface)\\s+([a-zA-Z_][a-zA-Z0-9_]*)",
					"captures": {
						"1": { "name": "keyword.other.interface.nudl" },
						"2": { "name": "entity.name.type.interface.nudl" }
					}
				},
				{
					"comment": "Actor declaration",
					"match": "\\b(actor)\\s+([a-zA-Z_][a-zA-Z0-9_]*)",
					"captures": {
						"1": { "name": "keyword.other.actor.nudl" },
						"2": { "name": "entity.name.type.actor.nudl" }
					}
				},
				{
					"comment": "Impl block: impl Interface for Type",
					"match": "\\b(impl)(?:\\s+([A-Z][a-zA-Z0-9_]*)\\s+(for)\\s+([A-Z][a-zA-Z0-9_]*))?",
					"captures": {
						"1": { "name": "keyword.other.impl.nudl" },
						"2": { "name": "entity.name.type.interface.nudl" },
						"3": { "name": "keyword.other.for.nudl" },
						"4": { "name": "entity.name.type.nudl" }
					}
				},
				{
					"comment": "Type alias",
					"match": "\\b(type)\\s+([a-zA-Z_][a-zA-Z0-9_]*)",
					"captures": {
						"1": { "name": "keyword.other.type.nudl" },
						"2": { "name": "entity.name.type.alias.nudl" }
					}
				},
				{
					"comment": "Extern block",
					"match": "\\b(extern)\\b",
					"captures": {
						"1": { "name": "keyword.other.extern.nudl" }
					}
				},
				{
					"comment": "Module declaration",
					"match": "\\b(mod)\\s+([a-zA-Z_][a-zA-Z0-9_]*)",
					"captures": {
						"1": { "name": "keyword.other.mod.nudl" },
						"2": { "name": "entity.name.namespace.nudl" }
					}
				}
			]
		},
		"constants": {
			"patterns": [
				{
					"name": "constant.language.boolean.true.nudl",
					"match": "\\btrue\\b"
				},
				{
					"name": "constant.language.boolean.false.nudl",
					"match": "\\bfalse\\b"
				},
				{
					"name": "constant.language.none.nudl",
					"match": "\\bNone\\b"
				}
			]
		},
		"self-keywords": {
			"patterns": [
				{
					"name": "variable.language.self.nudl",
					"match": "\\bself\\b"
				},
				{
					"name": "variable.language.self-type.nudl",
					"match": "\\bSelf\\b"
				}
			]
		},
		"keywords": {
			"patterns": [
				{
					"name": "keyword.control.nudl",
					"match": "\\b(?:if|else|match|for|while|loop|break|continue|return|in)\\b"
				},
				{
					"comment": "Postfix await after dot",
					"match": "(?<=\\.)\\b(await)\\b",
					"captures": {
						"1": { "name": "keyword.control.await.nudl" }
					}
				},
				{
					"name": "keyword.control.await.nudl",
					"match": "\\bawait\\b"
				},
				{
					"name": "storage.type.nudl",
					"match": "\\b(?:let|const|static)\\b"
				},
				{
					"name": "storage.modifier.nudl",
					"match": "\\b(?:pub|async|comptime|weak|dyn|mut)\\b"
				},
				{
					"name": "keyword.other.nudl",
					"match": "\\b(?:as|where|defer|quote|use)\\b"
				}
			]
		},
		"built-in-types": {
			"name": "support.type.nudl",
			"match": "\\b(?:i8|i16|i32|i64|u8|u16|u32|u64|f32|f64|bool|char|string|RawPtr|MutRawPtr|CStr|Option|Result|Future|Map|Range|RangeInclusive|WeakRef)\\b"
		},
		"operators": {
			"patterns": [
				{
					"name": "keyword.operator.pipe.nudl",
					"match": "\\|>"
				},
				{
					"name": "keyword.operator.arrow.fat.nudl",
					"match": "=>"
				},
				{
					"name": "keyword.operator.arrow.thin.nudl",
					"match": "->"
				},
				{
					"name": "keyword.operator.path.nudl",
					"match": "::"
				},
				{
					"name": "keyword.operator.spread.nudl",
					"match": "\\.\\.\\."
				},
				{
					"name": "keyword.operator.range.inclusive.nudl",
					"match": "\\.\\.="
				},
				{
					"name": "keyword.operator.range.nudl",
					"match": "\\.\\."
				},
				{
					"name": "keyword.operator.comparison.nudl",
					"match": "==|!=|<=|>="
				},
				{
					"name": "keyword.operator.logical.nudl",
					"match": "&&|\\|\\||!"
				},
				{
					"name": "keyword.operator.assignment.compound.nudl",
					"match": "\\+=|-=|\\*=|/=|%="
				},
				{
					"name": "keyword.operator.assignment.nudl",
					"match": "="
				},
				{
					"name": "keyword.operator.comparison.nudl",
					"match": "<|>"
				},
				{
					"name": "keyword.operator.arithmetic.nudl",
					"match": "\\+|-|\\*|/|%"
				},
				{
					"name": "keyword.operator.bitwise.nudl",
					"match": "<<|>>|&|\\||\\^"
				},
				{
					"name": "keyword.operator.question.nudl",
					"match": "\\?"
				}
			]
		},
		"function-call": {
			"match": "\\b([a-zA-Z_][a-zA-Z0-9_]*)\\s*(?=\\()",
			"captures": {
				"1": { "name": "entity.name.function.nudl" }
			}
		},
		"type-names": {
			"match": "\\b([A-Z][a-zA-Z0-9_]*)\\b",
			"captures": {
				"1": { "name": "entity.name.type.nudl" }
			}
		}
	}
}
