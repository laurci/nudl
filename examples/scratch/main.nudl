    print("\nsection: tuple structs\n");
    let pair = Pair(10, 20);
    print("  Pair(10, 20).sum() = "); print_num_ln(pair.sum());

    // ── 31. Type aliases (Phase 12) ──
    print("\nsection: type aliases\n");
    let score: Score = 100;
    print("  Score (type alias for i32) = "); print_num_ln(score);

    // ── 32. Operator overloading (Phase 12) ──
    print("\nsection: operator overloading\n");
    let v_a = Vec2 { x: 1, y: 2 };
    let v_b = Vec2 { x: 3, y: 4 };
    let v_sum = v_a + v_b;
    print("  Vec2(1,2) + Vec2(3,4) = (");
