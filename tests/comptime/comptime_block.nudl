// Test: Comptime blocks — comptime { expr } at top level and in function body
//
// A comptime block is evaluated at compile time. It may appear at the top
// level of a module or inside a function body. The result must be either a
// serializable value or a quote expression producing AST fragments.

// --- Top-level comptime block producing a constant ---
// The result of this comptime block is a compile-time constant.
comptime {
    let x = 6 * 7;
    // x == 42, serialized as a comptime constant
}

// --- Top-level comptime block generating a struct ---
comptime {
    let names = ["x", "y", "z"];
    quote {
        struct Vec3 {
            ${for name in names {
                quote { ${name}: f64, }
            }}
        }
    }
}

// --- Top-level comptime block generating a function ---
comptime {
    quote {
        fn generated_add(a: i32, b: i32) -> i32 {
            a + b
        }
    }
}

fn main() {
    // --- Use struct generated by top-level comptime block ---
    let v = Vec3 { x: 1.0, y: 2.0, z: 3.0 };
    assert(v.x == 1.0, "Vec3.x should be 1.0");
    assert(v.y == 2.0, "Vec3.y should be 2.0");
    assert(v.z == 3.0, "Vec3.z should be 3.0");

    // --- Use function generated by comptime ---
    let sum = generated_add(10, 20);
    assert(sum == 30, "generated_add(10, 20) should be 30");

    // --- Comptime block inside a function body producing a constant ---
    let magic = comptime { 6 * 7 };
    assert(magic == 42, "comptime { 6 * 7 } should be 42");

    // --- Comptime block with more complex computation ---
    let fib10 = comptime {
        // Compute fibonacci(10) at compile time
        let mut a = 0;
        let mut b = 1;
        for _ in 0..10 {
            let temp = b;
            b = a + b;
            a = temp;
        }
        a
    };
    assert(fib10 == 55, "fibonacci(10) should be 55");

    // --- Comptime block producing a string constant ---
    let greeting = comptime {
        let parts = ["Hello", ", ", "World", "!"];
        let mut result = "";
        for part in parts {
            result = `{result}{part}`;
        }
        result
    };
    assert(greeting == "Hello, World!", "comptime string should be 'Hello, World!'");

    // --- Comptime block with conditionals ---
    let platform_value = comptime {
        let is_debug = true;
        if is_debug {
            100
        } else {
            0
        }
    };
    assert(platform_value == 100, "comptime conditional should evaluate to 100");

    println("comptime_block: all assertions passed");
}
