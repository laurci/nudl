// Test: Comptime parameters — fn f(comptime size: u32), used in type positions
//
// Functions may accept comptime parameters: values that must be known at
// compile time. The `comptime` keyword before a parameter name indicates
// this requirement. Comptime params can be used in type positions.

// --- Comptime parameter used as fixed array size ---
fn create_zeros(comptime size: u32) -> [i32; size] {
    [0; size]
}

fn create_ones(comptime size: u32) -> [f64; size] {
    [1.0; size]
}

// --- Comptime parameter controlling behavior ---
fn create_array<T>(comptime size: u32) -> [T; size] {
    [T::default(); size]
}

// --- Comptime parameter with bit width ---
fn bit_set(comptime width: u32) -> [bool; width] {
    [false; width]
}

// --- Comptime parameter in struct-like pattern ---
fn make_matrix(comptime rows: u32, comptime cols: u32) -> [[f64; cols]; rows] {
    [[0.0; cols]; rows]
}

// --- Comptime parameter used in computation ---
fn sum_first_n(comptime n: u32) -> i32 {
    let arr = create_zeros(n);
    let mut sum = 0;
    for i in 0..n {
        sum = sum + (i as i32) + 1;
    }
    sum
}

// --- Comptime string parameter ---
fn labeled_value(comptime label: string, value: i32) -> string {
    f"{label}: {value}"
}

fn main() {
    // --- Fixed-size array from comptime param ---
    let zeros3 = create_zeros(3);
    assert(zeros3.len() == 3, "should have 3 zeros");
    assert(zeros3[0] == 0, "all elements should be 0");
    assert(zeros3[2] == 0, "last element should be 0");

    let zeros10 = create_zeros(10);
    assert(zeros10.len() == 10, "should have 10 zeros");

    // --- Different sizes, same function ---
    let ones4 = create_ones(4);
    assert(ones4.len() == 4, "should have 4 ones");
    assert(ones4[0] == 1.0, "all elements should be 1.0");

    let ones1 = create_ones(1);
    assert(ones1.len() == 1, "should have 1 one");

    // --- Bit set ---
    let mut bits = bit_set(8);
    assert(bits.len() == 8, "should have 8 bits");
    assert(bits[0] == false, "all bits start false");
    bits[0] = true;
    bits[7] = true;
    assert(bits[0] == true, "bit 0 should be set");
    assert(bits[7] == true, "bit 7 should be set");
    assert(bits[3] == false, "bit 3 should still be false");

    // --- Matrix ---
    let mat = make_matrix(2, 3);
    assert(mat.len() == 2, "should have 2 rows");
    assert(mat[0].len() == 3, "each row should have 3 cols");
    assert(mat[1][2] == 0.0, "all elements should be 0.0");

    // --- Comptime param in computation ---
    let sum5 = sum_first_n(5);
    assert(sum5 == 15, "sum of 1..=5 should be 15");

    let sum10 = sum_first_n(10);
    assert(sum10 == 55, "sum of 1..=10 should be 55");

    // --- Comptime string param ---
    let msg = labeled_value("count", value: 42);
    assert(msg == "count: 42", "labeled value should format correctly");

    // --- Comptime params must be known at compile time ---
    // let n = 5;
    // create_zeros(n);  // ERROR: n is not a comptime-known value

    println("comptime_params: all assertions passed");
}
