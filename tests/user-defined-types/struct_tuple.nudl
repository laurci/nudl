// Test: Tuple structs — struct Name(T1, T2), positional field access with .0, .1, etc.

// Basic tuple struct
struct Color(u8, u8, u8);

// Single-field tuple struct (newtype pattern)
struct Meters(f64);
struct Seconds(f64);

// Multi-field tuple struct
struct Pair(i32, i32);

// Tuple struct with mixed types
struct TaggedValue(string, i64);

// Tuple struct with reference types
struct NamedList(string, i32[]);

fn main() {
    // --- Basic construction ---
    let red = Color(255, 0, 0);
    let green = Color(0, 255, 0);
    let blue = Color(0, 0, 255);

    // --- Positional field access (.0, .1, .2) ---
    println(f"Red: r={red.0}, g={red.1}, b={red.2}");
    println(f"Green: r={green.0}, g={green.1}, b={green.2}");
    println(f"Blue: r={blue.0}, g={blue.1}, b={blue.2}");

    // --- Newtype pattern ---
    let distance = Meters(100.0);
    let time = Seconds(9.58);
    println(f"Distance: {distance.0}m in {time.0}s");

    // Speed calculation using newtype inner values
    let speed = distance.0 / time.0;
    println(f"Speed: {speed} m/s");

    // --- Pair ---
    let coords = Pair(10, 20);
    println(f"Pair: ({coords.0}, {coords.1})");

    // --- Tagged value ---
    let tv = TaggedValue("count", 42);
    println(f"Tag: {tv.0}, Value: {tv.1}");

    // --- Tuple struct with collections ---
    let list = NamedList("primes", [2, 3, 5, 7, 11]);
    println(f"List '{list.0}' has {list.1.len()} items");

    // --- Mutable tuple struct fields ---
    let mut c = Color(100, 100, 100);
    c.0 = 200;
    c.1 = 150;
    c.2 = 50;
    println(f"Modified color: ({c.0}, {c.1}, {c.2})");

    // --- Pattern matching on tuple structs ---
    let color = Color(0, 0, 0);
    let name = match color {
        Color(0, 0, 0) => "black",
        Color(255, 255, 255) => "white",
        Color(255, 0, 0) => "red",
        Color(0, 255, 0) => "green",
        Color(0, 0, 255) => "blue",
        Color(r, g, b) => f"custom({r}, {g}, {b})",
    };
    println(f"Color name: {name}");

    // --- Destructuring in let ---
    let Color(r, g, b) = red;
    println(f"Destructured red: r={r}, g={g}, b={b}");

    let Meters(dist) = distance;
    println(f"Distance value: {dist}");

    // --- Tuple struct in a collection ---
    let palette: Color[] = [
        Color(255, 0, 0),
        Color(0, 255, 0),
        Color(0, 0, 255),
        Color(255, 255, 0),
    ];
    for c in palette {
        println(f"  ({c.0}, {c.1}, {c.2})");
    }

    // --- Tuple struct as function parameter and return ---
    let mixed = mix_colors(red, green);
    println(f"Mixed: ({mixed.0}, {mixed.1}, {mixed.2})");
}

fn mix_colors(a: Color, b: Color) -> Color {
    Color(
        ((a.0 as i32 + b.0 as i32) / 2) as u8,
        ((a.1 as i32 + b.1 as i32) / 2) as u8,
        ((a.2 as i32 + b.2 as i32) / 2) as u8,
    )
}
