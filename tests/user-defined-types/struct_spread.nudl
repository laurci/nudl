// Test: Struct spread syntax — Point { ...base, x: 5.0 }
// Spread must come first in the struct literal.

struct Point {
    x: f64,
    y: f64,
}

struct Config {
    host: string,
    port: u16,
    tls: bool,
    timeout: u64,
}

struct Color {
    r: u8,
    g: u8,
    b: u8,
    a: u8,
}

fn main() {
    // --- Basic spread: override one field ---
    let base = Point { x: 1.0, y: 2.0 };
    let moved = Point { ...base, x: 5.0 };
    println(`moved: ({moved.x}, {moved.y})`);
    // moved.x == 5.0, moved.y == 2.0 (from base)

    // --- Spread: override a different field ---
    let shifted = Point { ...base, y: 10.0 };
    println(`shifted: ({shifted.x}, {shifted.y})`);
    // shifted.x == 1.0 (from base), shifted.y == 10.0

    // --- Spread with no overrides (copy all fields) ---
    let copy = Point { ...base };
    println(`copy: ({copy.x}, {copy.y})`);

    // --- Spread with all fields overridden ---
    let fresh = Point { ...base, x: 100.0, y: 200.0 };
    println(`fresh: ({fresh.x}, {fresh.y})`);

    // --- Config spread: update one setting ---
    let default_config = Config {
        host: "localhost",
        port: 8080,
        tls: false,
        timeout: 30000,
    };

    let prod_config = Config { ...default_config, host: "prod.example.com", tls: true };
    println(`prod: {prod_config.host}:{prod_config.port} tls={prod_config.tls}`);
    // host overridden, port and timeout from default_config

    let custom_port = Config { ...default_config, port: 443 };
    println(`custom port: {custom_port.host}:{custom_port.port}`);

    // --- Chained spreads ---
    let base_color = Color { r: 255, g: 128, b: 64, a: 255 };
    let transparent = Color { ...base_color, a: 128 };
    let blue_transparent = Color { ...transparent, b: 200 };
    println(`blue transparent: r={blue_transparent.r} g={blue_transparent.g} b={blue_transparent.b} a={blue_transparent.a}`);

    // --- Spread in function return ---
    let adjusted = with_alpha(base_color, 0);
    println(`adjusted: a={adjusted.a}`);

    // --- Spread from function parameter ---
    let moved_point = offset(base, 10.0, 20.0);
    println(`offset: ({moved_point.x}, {moved_point.y})`);

    // --- Spread in a loop ---
    let origin = Point { x: 0.0, y: 0.0 };
    let mut points: Point[] = [];
    for i in 0..5 {
        let p = Point { ...origin, x: i as f64 };
        points.push(p);
    }
    for p in points {
        println(`  point: ({p.x}, {p.y})`);
    }

    // --- Original struct is unchanged after spread ---
    println(`base still: ({base.x}, {base.y})`);
    println(`default_config still: {default_config.host}:{default_config.port}`);
}

fn with_alpha(color: Color, alpha: u8) -> Color {
    Color { ...color, a: alpha }
}

fn offset(point: Point, dx: f64, dy: f64) -> Point {
    Point { ...point, x: point.x + dx, y: point.y + dy }
}
