// Module: math
// Provides multiple arithmetic functions for grouped import testing.

pub fn add(a: i32, b: i32) -> i32 {
    a + b
}

pub fn subtract(a: i32, b: i32) -> i32 {
    a - b
}

pub fn multiply(a: i32, b: i32) -> i32 {
    a * b
}

// Private function — should NOT be importable from outside
fn internal_helper(x: i32) -> i32 {
    x * x
}
