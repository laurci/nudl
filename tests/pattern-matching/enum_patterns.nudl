// Test: Enum patterns — matching unit variants, data (tuple) variants,
//       and struct variants in match expressions.

// Unit variants only
enum Direction {
    North,
    South,
    East,
    West,
}

// Tuple (data) variants
enum Shape {
    Circle(f64),
    Rectangle(f64, f64),
    Point,
}

// Struct variants
enum Message {
    Quit,
    Echo(string),
    Move { x: i32, y: i32 },
    Color { r: u8, g: u8, b: u8 },
}

// Mixed variant types
enum Expr {
    Literal(i32),
    Add(i32, i32),
    Neg(i32),
    Named { name: string, value: i32 },
}

// Recursive-like enum with Option
enum Tree {
    Leaf(i32),
    Node { value: i32, left: Option<i32>, right: Option<i32> },
}

fn direction_name(d: Direction) -> string {
    match d {
        Direction::North => "North",
        Direction::South => "South",
        Direction::East => "East",
        Direction::West => "West",
    }
}

fn shape_area(s: Shape) -> f64 {
    match s {
        Shape::Circle(r) => 3.14159 * r * r,
        Shape::Rectangle(w, h) => w * h,
        Shape::Point => 0.0,
    }
}

fn process_message(msg: Message) -> string {
    match msg {
        Message::Quit => "Quitting",
        Message::Echo(text) => f"Echo: {text}",
        Message::Move { x, y } => f"Moving to ({x}, {y})",
        Message::Color { r, g, b } => f"Color: rgb({r}, {g}, {b})",
    }
}

fn eval_expr(e: Expr) -> i32 {
    match e {
        Expr::Literal(v) => v,
        Expr::Add(a, b) => a + b,
        Expr::Neg(v) => -v,
        Expr::Named { value, .. } => value,
    }
}

fn main() {
    // Unit variant matching
    let dirs = [Direction::North, Direction::South, Direction::East, Direction::West];
    for d in dirs {
        println(f"Direction: {direction_name(d)}");
    }

    // Data (tuple) variant matching
    let shapes = [
        Shape::Circle(5.0),
        Shape::Rectangle(10.0, 20.0),
        Shape::Point,
    ];
    for s in shapes {
        println(f"Shape area: {shape_area(s)}");
    }

    // Struct variant matching
    let messages = [
        Message::Quit,
        Message::Echo("hello"),
        Message::Move { x: 10, y: 20 },
        Message::Color { r: 255, g: 128, b: 0 },
    ];
    for msg in messages {
        println(process_message(msg));
    }

    // Mixed variant matching with Expr
    let expressions = [
        Expr::Literal(42),
        Expr::Add(10, 20),
        Expr::Neg(5),
        Expr::Named { name: "pi_approx", value: 3 },
    ];
    for e in expressions {
        println(f"Eval: {eval_expr(e)}");
    }

    // Matching with guards on enum data
    let shape = Shape::Circle(15.0);
    let desc = match shape {
        Shape::Circle(r) if r > 10.0 => f"large circle (r={r})",
        Shape::Circle(r) => f"small circle (r={r})",
        Shape::Rectangle(w, h) if w == h => f"square ({w}x{h})",
        Shape::Rectangle(w, h) => f"rectangle ({w}x{h})",
        Shape::Point => "point",
    };
    println(desc);

    // Enum in if-let
    let msg = Message::Move { x: 5, y: 10 };
    if let Message::Move { x, y } = msg {
        println(f"Move detected: ({x}, {y})");
    }

    // Enum matching with nested data
    let tree = Tree::Node { value: 10, left: Some(5), right: Some(15) };
    match tree {
        Tree::Leaf(v) => println(f"Leaf: {v}"),
        Tree::Node { value, left: Some(l), right: Some(r) } => {
            println(f"Node({value}) with left={l}, right={r}");
        },
        Tree::Node { value, left: None, right: Some(r) } => {
            println(f"Node({value}) with right={r} only");
        },
        Tree::Node { value, left: Some(l), right: None } => {
            println(f"Node({value}) with left={l} only");
        },
        Tree::Node { value, .. } => {
            println(f"Node({value}) with no children");
        },
    }

    // Using qualified enum paths
    let opt: Option<i32> = Some(42);
    match opt {
        Option::Some(v) => println(f"Option::Some({v})"),
        Option::None => println("Option::None"),
    }

    // Result enum patterns
    let res: Result<i32, string> = Ok(200);
    match res {
        Ok(code) => println(f"Ok({code})"),
        Err(msg) => println(f"Err({msg})"),
    }
}
