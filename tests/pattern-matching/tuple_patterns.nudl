// Test: Tuple patterns — destructuring tuples in match, let, and for.

fn classify_point(point: (i32, i32)) -> string {
    match point {
        (0, 0) => "origin",
        (x, 0) => `on x-axis at {x}`,
        (0, y) => `on y-axis at {y}`,
        (x, y) if x == y => `on diagonal at ({x}, {y})`,
        (x, y) if x > 0 && y > 0 => `quadrant I: ({x}, {y})`,
        (x, y) if x < 0 && y > 0 => `quadrant II: ({x}, {y})`,
        (x, y) if x < 0 && y < 0 => `quadrant III: ({x}, {y})`,
        (x, y) => `quadrant IV: ({x}, {y})`,
    }
}

fn main() {
    // Basic tuple destructuring in match
    let point = (3, 4);
    match point {
        (x, y) => println(`Point: ({x}, {y})`),
    }

    // Tuple matching with literal values
    let pair = (1, 2);
    let desc = match pair {
        (1, 2) => "one-two",
        (1, _) => "one-something",
        (_, 2) => "something-two",
        _ => "other",
    };
    println(`Pair ({pair.0}, {pair.1}): {desc}`);

    // Classify points using function
    println(classify_point((0, 0)));
    println(classify_point((5, 0)));
    println(classify_point((0, -3)));
    println(classify_point((7, 7)));
    println(classify_point((3, 4)));
    println(classify_point((-2, 5)));
    println(classify_point((-3, -4)));
    println(classify_point((4, -1)));

    // Triple tuple pattern
    let rgb = (255, 128, 0);
    match rgb {
        (255, 0, 0) => println("Pure red"),
        (0, 255, 0) => println("Pure green"),
        (0, 0, 255) => println("Pure blue"),
        (255, 128, 0) => println("Orange"),
        (r, g, b) => println(`Color: rgb({r}, {g}, {b})`),
    }

    // Tuple destructuring in let binding
    let (a, b, c) = (10, 20, 30);
    println(`a={a}, b={b}, c={c}`);

    // Nested tuple patterns
    let nested = ((1, 2), (3, 4));
    match nested {
        ((a, b), (c, d)) => println(`Nested: ({a},{b}), ({c},{d})`),
    }

    // Tuple patterns in for loop
    let pairs = [(1, "one"), (2, "two"), (3, "three")];
    for (num, name) in pairs {
        println(`  {num} = {name}`);
    }

    // Mix of tuple and wildcard patterns
    let data = (true, 42, "hello");
    match data {
        (true, n, _) if n > 10 => println(`True with large number: {n}`),
        (true, n, s) => println(`True: {n}, {s}`),
        (false, _, _) => println("False"),
    }

    // Tuple in Option
    let maybe_pair: Option<(i32, i32)> = Some((5, 10));
    match maybe_pair {
        Some((x, y)) => println(`Got pair: ({x}, {y})`),
        None => println("No pair"),
    }

    // Tuple with mixed types
    let record = ("Alice", 30, true);
    let (name, age, active) = record;
    println(`Name: {name}, Age: {age}, Active: {active}`);

    // Two-element tuple with swap
    let (x, y) = (1, 2);
    let (y2, x2) = (x, y);
    println(`Swapped: x={x2}, y={y2}`);
}
