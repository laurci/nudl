// Test: Monomorphization — same generic fn/struct, different concrete types

// Generic function that will be monomorphized for each call site
fn double<T: Add<T, T> + Clone>(value: T) -> T {
    value.clone() + value
}

// Generic struct monomorphized per type argument
struct Stack<T> {
    items: T[],
}

impl<T> Stack<T> {
    fn new() -> Stack<T> {
        Stack { items: [] }
    }

    fn push(mut self, item: T) {
        self.items.push(item);
    }

    fn pop(mut self) -> Option<T> {
        self.items.pop()
    }

    fn len(self) -> i32 {
        self.items.len() as i32
    }
}

// Each usage generates a separate monomorphized copy
fn max<T: Ord>(a: T, b: T) -> T {
    if a > b { a } else { b }
}

fn min<T: Ord>(a: T, b: T) -> T {
    if a < b { a } else { b }
}

// Generic enum monomorphized
enum Holder<T> {
    Value(T),
    Empty,
}

impl<T: Printable> Holder<T> {
    fn describe(self) -> string {
        match self {
            Holder::Value(v) => `holding: {v.to_string()}`,
            Holder::Empty => "empty",
        }
    }
}

fn main() {
    // double<i32> — one monomorphized copy
    let a = double(21);          // 42: i32

    // double<f64> — another monomorphized copy
    let b = double(1.5);         // 3.0: f64

    // Stack<i32> — monomorphized for i32
    let mut int_stack = Stack::new::<i32>();
    int_stack.push(1);
    int_stack.push(2);
    int_stack.push(3);

    // Stack<string> — separate monomorphized copy for string
    let mut str_stack = Stack::new::<string>();
    str_stack.push("hello");
    str_stack.push("world");

    // max monomorphized for different types
    let max_int = max(10, 20);          // max<i32>
    let max_float = max(3.14, 2.71);   // max<f64>
    let max_char = max('a', 'z');       // max<char>

    // Holder<i32> vs Holder<string>
    let h1 = Holder::Value(42);
    let h2 = Holder::Value("hello");
    let h3: Holder<f64> = Holder::Empty;

    println(`double(21) = {a}`);
    println(`double(1.5) = {b}`);
    println(`int_stack len: {int_stack.len()}`);
    println(`str_stack len: {str_stack.len()}`);
    println(`max_int: {max_int}`);
    println(`max_float: {max_float}`);
    println(`h1: {h1.describe()}`);
    println(`h2: {h2.describe()}`);
    println(`h3: {h3.describe()}`);
}
