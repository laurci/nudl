// Test: Where clauses — where T: Clone, U: Printable

interface Printable {
    fn to_string(self) -> string;
}

interface Summary {
    fn summarize(self) -> string;
}

// Where clause with multiple predicates
fn merge_descriptions<A, B>(a: A, b: B) -> string
where
    A: Printable + Summary,
    B: Printable + Summary,
{
    let a_summary = a.summarize();
    let b_summary = b.summarize();
    a_summary
}

struct Article {
    title: string,
    body: string,
}

impl Printable for Article {
    fn to_string(self) -> string {
        self.title
    }
}

impl Summary for Article {
    fn summarize(self) -> string {
        self.title
    }
}

fn main() {
    let a = Article { title: "Hello", body: "content" };
    let b = Article { title: "World", body: "more" };

    let merged = merge_descriptions(a, b: b);
    println(merged);
}
