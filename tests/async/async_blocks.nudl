// Test: Async blocks — async { expr } produces Future<T>

async fn fetch_name() -> string {
    "World"
}

async fn main() {
    // Basic async block — produces Future<string>
    let greeting: Future<string> = async {
        let name = fetch_name().await;
        f"Hello, {name}!"
    };
    let message = greeting.await;
    println(message);

    // Async block capturing variables from enclosing scope
    let prefix = "Greetings";
    let custom: Future<string> = async {
        let name = fetch_name().await;
        f"{prefix}, {name}!"  // captures prefix by ARC ref
    };
    println(custom.await);

    // Async block as expression
    let value = async { 42 }.await;
    println(f"value: {value}");

    // Async block with multiple statements
    let result = async {
        let a = async { 10 }.await;
        let b = async { 20 }.await;
        a + b
    }.await;
    println(f"result: {result}");

    // Async block with control flow
    let computed = async {
        let mut sum = 0;
        for i in 1..=10 {
            sum += i;
        }
        sum
    }.await;
    println(f"sum 1..10: {computed}");

    // Async block returning unit
    let unit_future: Future<()> = async {
        println("Side effect in async block");
    };
    unit_future.await;
}
