// Test: Task.spawn — concurrent task execution

async fn compute_square(n: i32) -> i32 {
    n * n
}

async fn slow_operation(label: string) -> string {
    f"completed: {label}"
}

async fn main() {
    // Basic Task.spawn — returns TaskHandle<T> which is a Future<T>
    let handle = Task.spawn(async { compute_square(7).await });
    let result = handle.await;
    println(f"7 squared = {result}");

    // Spawn multiple concurrent tasks
    let h1 = Task.spawn(async { slow_operation("task A").await });
    let h2 = Task.spawn(async { slow_operation("task B").await });
    let h3 = Task.spawn(async { slow_operation("task C").await });

    // Await all — they run concurrently (cooperative scheduling)
    let r1 = h1.await;
    let r2 = h2.await;
    let r3 = h3.await;
    println(f"{r1}, {r2}, {r3}");

    // Spawn with captured variables
    let multiplier = 3;
    let handle = Task.spawn(async {
        let base = compute_square(5).await;
        base * multiplier  // captures multiplier by ARC ref
    });
    println(f"5^2 * 3 = {handle.await}");

    // Spawned task lifetime bound to enclosing scope (structured concurrency)
    {
        let scoped = Task.spawn(async { slow_operation("scoped").await });
        let scoped_result = scoped.await;
        println(scoped_result);
    }
}
