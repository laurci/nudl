// Test: Inherent methods — impl Type { } without interface, static methods

struct Point {
    x: f64,
    y: f64,
}

struct Circle {
    center: Point,
    radius: f64,
}

struct Counter {
    value: i32,
    max: i32,
}

// --- Inherent methods on Point ---
impl Point {
    // Static method (no self parameter) — acts as a constructor
    fn new(x: f64, y: f64) -> Point {
        Point { x, y }
    }

    // Another static method
    fn origin() -> Point {
        Point { x: 0.0, y: 0.0 }
    }

    // Instance method (takes self)
    fn distance_to(self, other: Point) -> f64 {
        let dx = self.x - other.x;
        let dy = self.y - other.y;
        // simplified: return squared distance (no sqrt built-in yet)
        dx * dx + dy * dy
    }

    // Instance method returning a new Point
    fn offset(self, dx: f64, dy: f64) -> Point {
        Point { x: self.x + dx, y: self.y + dy }
    }

    // Method that takes mut self
    fn translate(mut self, dx: f64, dy: f64) {
        self.x += dx;
        self.y += dy;
    }

    // Method returning a string
    fn display(self) -> string {
        f"({self.x}, {self.y})"
    }
}

// --- Inherent methods on Circle ---
impl Circle {
    fn new(x: f64, y: f64, radius: f64) -> Circle {
        Circle {
            center: Point::new(x, y),
            radius,
        }
    }

    fn unit() -> Circle {
        Circle::new(0.0, 0.0, 1.0)
    }

    fn area(self) -> f64 {
        3.14159 * self.radius * self.radius
    }

    fn circumference(self) -> f64 {
        2.0 * 3.14159 * self.radius
    }

    fn contains(self, point: Point) -> bool {
        let dist_sq = self.center.distance_to(point);
        dist_sq <= self.radius * self.radius
    }

    fn scale(self, factor: f64) -> Circle {
        Circle {
            center: self.center,
            radius: self.radius * factor,
        }
    }
}

// --- Inherent methods with mut self ---
impl Counter {
    fn new(max: i32) -> Counter {
        Counter { value: 0, max }
    }

    fn get(self) -> i32 {
        self.value
    }

    fn is_maxed(self) -> bool {
        self.value >= self.max
    }

    fn increment(mut self) -> bool {
        if self.value < self.max {
            self.value += 1;
            true
        } else {
            false
        }
    }

    fn reset(mut self) {
        self.value = 0;
    }
}

// Enum with inherent methods
enum Color {
    Red,
    Green,
    Blue,
    Custom(u8, u8, u8),
}

impl Color {
    fn red() -> Color {
        Color::Red
    }

    fn rgb(r: u8, g: u8, b: u8) -> Color {
        Color::Custom(r, g, b)
    }

    fn name(self) -> string {
        match self {
            Color::Red => "red",
            Color::Green => "green",
            Color::Blue => "blue",
            Color::Custom(r, g, b) => f"rgb({r},{g},{b})",
        }
    }

    fn is_primary(self) -> bool {
        match self {
            Color::Red | Color::Green | Color::Blue => true,
            _ => false,
        }
    }
}

fn main() {
    // --- Static constructor methods ---
    let p1 = Point::new(3.0, 4.0);
    println(f"p1: {p1.display()}");

    let origin = Point::origin();
    println(f"origin: {origin.display()}");

    // --- Instance methods ---
    let dist = p1.distance_to(origin);
    println(f"distance^2 from p1 to origin: {dist}");

    let p2 = p1.offset(1.0, -1.0);
    println(f"p1 offset by (1,-1): {p2.display()}");

    // --- Mutable self methods ---
    let mut p3 = Point::new(0.0, 0.0);
    p3.translate(5.0, 10.0);
    println(f"p3 after translate: {p3.display()}");

    // --- Circle static and instance methods ---
    let c = Circle::new(0.0, 0.0, 5.0);
    println(f"Circle area: {c.area()}");
    println(f"Circle circumference: {c.circumference()}");

    let unit = Circle::unit();
    println(f"Unit circle area: {unit.area()}");

    // --- Method that calls other methods ---
    let inside = Point::new(1.0, 1.0);
    let outside = Point::new(10.0, 10.0);
    println(f"(1,1) inside circle: {c.contains(inside)}");
    println(f"(10,10) inside circle: {c.contains(outside)}");

    // --- Method chaining ---
    let big_circle = Circle::unit().scale(10.0);
    println(f"Big circle area: {big_circle.area()}");

    // --- Counter with mut self ---
    let mut counter = Counter::new(3);
    println(f"Counter: {counter.get()}, maxed: {counter.is_maxed()}");

    counter.increment();
    counter.increment();
    counter.increment();
    println(f"After 3 increments: {counter.get()}, maxed: {counter.is_maxed()}");

    let could_increment = counter.increment();
    println(f"4th increment succeeded: {could_increment}");

    counter.reset();
    println(f"After reset: {counter.get()}");

    // --- Enum inherent methods ---
    let c1 = Color::red();
    let c2 = Color::rgb(128, 64, 32);
    println(f"c1: {c1.name()}, primary: {c1.is_primary()}");
    println(f"c2: {c2.name()}, primary: {c2.is_primary()}");

    println("All inherent method tests passed");
}
