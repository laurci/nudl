// Test: for-in loops over arrays, ranges (exclusive 0..10, inclusive 0..=10),
//       enumerate(), destructuring in for patterns.

fn main() {
    // For-in over an array
    let fruits = ["apple", "banana", "cherry"];
    for fruit in fruits {
        println(`Fruit: {fruit}`);
    }

    // For-in over an exclusive range (0..5 gives 0,1,2,3,4)
    println("Exclusive range 0..5:");
    for i in 0..5 {
        println(`  i = {i}`);
    }

    // For-in over an inclusive range (0..=5 gives 0,1,2,3,4,5)
    println("Inclusive range 0..=5:");
    for i in 0..=5 {
        println(`  i = {i}`);
    }

    // For-in with enumerate() to get index and value
    let colors = ["red", "green", "blue", "yellow"];
    for (index, color) in colors.enumerate() {
        println(`  [{index}] = {color}`);
    }

    // For-in over a range computing values
    let mut sum = 0;
    for i in 1..=100 {
        sum += i;
    }
    println(`Sum 1..=100 = {sum}`);

    // For-in with array of integers
    let numbers = [10, 20, 30, 40, 50];
    let mut total = 0;
    for n in numbers {
        total += n;
    }
    println(`Total = {total}`);

    // Nested for loops
    println("Multiplication table (1-5):");
    for i in 1..=5 {
        let mut row = "";
        for j in 1..=5 {
            let product = i * j;
            row = `{row} {product}`;
        }
        println(`  {row}`);
    }

    // For-in over characters of a string
    for ch in "hello".chars() {
        println(`char: {ch}`);
    }

    // For-in with tuple destructuring over array of tuples
    let pairs = [(1, "one"), (2, "two"), (3, "three")];
    for (num, name) in pairs {
        println(`{num} = {name}`);
    }

    // For-in building a new collection
    let mut squares: i32[] = [];
    for i in 0..10 {
        squares.push(i * i);
    }
    println(`Squares: {squares}`);

    // For-in with enumerate on a range-produced collection
    let items = [100, 200, 300];
    for (i, val) in items.enumerate() {
        println(`items[{i}] = {val}`);
    }

    // For loop over empty array (body never executes)
    let empty: i32[] = [];
    for x in empty {
        println(`This should not print: {x}`);
    }
    println("Empty loop completed");

    // For loop over single-element range
    for i in 0..1 {
        println(`Single iteration: {i}`);
    }

    // For loop with mutable accumulation
    let mut max_val = 0;
    let values = [3, 7, 2, 9, 1, 8, 4];
    for v in values {
        if v > max_val {
            max_val = v;
        }
    }
    println(`Max value = {max_val}`);
}
