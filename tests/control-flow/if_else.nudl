// Test: if/else as statement and expression, else-if chains,
//       types must match in expression context.

fn main() {
    // if as statement (no else required)
    let x = 10;
    if x > 0 {
        println("x is positive");
    }

    // if/else as statement
    if x % 2 == 0 {
        println("x is even");
    } else {
        println("x is odd");
    }

    // if/else as expression: both branches must have same type
    let abs_x = if x >= 0 { x } else { -x };
    println(f"abs({x}) = {abs_x}");

    let neg = -7;
    let abs_neg = if neg >= 0 { neg } else { -neg };
    println(f"abs({neg}) = {abs_neg}");

    // else-if chain as statement
    let score = 85;
    if score >= 90 {
        println("Grade: A");
    } else if score >= 80 {
        println("Grade: B");
    } else if score >= 70 {
        println("Grade: C");
    } else if score >= 60 {
        println("Grade: D");
    } else {
        println("Grade: F");
    }

    // else-if chain as expression
    let category = if score >= 90 {
        "excellent"
    } else if score >= 70 {
        "good"
    } else if score >= 50 {
        "passing"
    } else {
        "failing"
    };
    println(f"score {score} is {category}");

    // Nested if/else expressions
    let a = 5;
    let b = 10;
    let result = if a > b {
        if a > 20 { "a is very large" } else { "a is larger" }
    } else {
        if b > 20 { "b is very large" } else { "b is larger" }
    };
    println(result);

    // if/else with block bodies containing multiple statements
    let mut message = "";
    if x > 5 {
        let doubled = x * 2;
        message = f"doubled: {doubled}";
    } else {
        let halved = x / 2;
        message = f"halved: {halved}";
    }
    println(message);

    // if expression assigning to let (both branches return same type)
    let sign = if x > 0 { 1 } else if x < 0 { -1 } else { 0 };
    println(f"sign of {x} = {sign}");

    // if with boolean variable
    let is_valid = true;
    if is_valid {
        println("valid");
    }

    // if with logical operators
    let age = 25;
    let has_id = true;
    if age >= 18 && has_id {
        println("access granted");
    } else {
        println("access denied");
    }

    // if/else expression used in function call
    let label = if x > 0 { "positive" } else { "non-positive" };
    println(f"x is {label}");

    // Chained conditions with complex expressions
    let temp = 72;
    let weather = if temp > 85 {
        "hot"
    } else if temp > 65 {
        "pleasant"
    } else if temp > 45 {
        "cool"
    } else if temp > 32 {
        "cold"
    } else {
        "freezing"
    };
    println(f"{temp}F is {weather}");
}
