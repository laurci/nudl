// Test: loop { } (infinite loops), break with value, loop as expression.

fn main() {
    // Basic loop with break
    let mut count = 0;
    loop {
        count += 1;
        if count >= 5 {
            break;
        }
    }
    println(`Loop ran {count} times`);

    // Loop as expression: break with a value
    let result = loop {
        count += 1;
        if count >= 10 {
            break count;
        }
    };
    println(`Loop returned: {result}`);

    // Loop with break value: finding first match
    let numbers = [3, 7, 1, 9, 4, 6, 2];
    let mut idx = 0;
    let first_even = loop {
        if idx >= numbers.len() {
            break -1;
        }
        if numbers[idx] % 2 == 0 {
            break numbers[idx];
        }
        idx += 1;
    };
    println(`First even number: {first_even}`);

    // Loop with complex break condition
    let mut a = 1;
    let mut b = 1;
    let fib_over_100 = loop {
        let next = a + b;
        a = b;
        b = next;
        if b > 100 {
            break b;
        }
    };
    println(`First Fibonacci over 100: {fib_over_100}`);

    // Nested loop with inner break
    let mut outer_count = 0;
    loop {
        let mut inner_count = 0;
        loop {
            inner_count += 1;
            if inner_count >= 3 {
                break;
            }
        }
        outer_count += 1;
        if outer_count >= 4 {
            break;
        }
    }
    println(`Outer loop ran {outer_count} times`);

    // Loop as expression assigned to variable with string value
    let mut attempts = 0;
    let status = loop {
        attempts += 1;
        if attempts >= 3 {
            break "success";
        }
    };
    println(`Status after {attempts} attempts: {status}`);

    // Loop with continue-like behavior (using if to skip)
    let mut sum = 0;
    let mut i = 0;
    loop {
        i += 1;
        if i > 20 {
            break;
        }
        if i % 3 == 0 {
            // Skip multiples of 3
            continue;
        }
        sum += i;
    }
    println(`Sum (skipping multiples of 3, 1..20): {sum}`);

    // Loop returning a computed value
    let mut n = 1;
    let power_of_two = loop {
        n = n * 2;
        if n >= 1000 {
            break n;
        }
    };
    println(`First power of 2 >= 1000: {power_of_two}`);

    // Loop expression used directly in a function call argument
    let mut counter = 0;
    println(`Loop value: {loop {
        counter += 1;
        if counter == 5 {
            break counter * 10;
        }
    }}`);
}
