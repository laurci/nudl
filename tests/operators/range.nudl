// Test: Range operators — .., ..= in for loops and match patterns
// Covers: exclusive range (..), inclusive range (..=),
//         range in for loops, range patterns in match

fn main() {
    // --- Exclusive range in for loop ---
    let mut sum_excl = 0;
    for i in 0..10 {
        sum_excl += i;
    }
    // sum_excl should be 0+1+2+...+9 = 45

    // --- Inclusive range in for loop ---
    let mut sum_incl = 0;
    for i in 0..=10 {
        sum_incl += i;
    }
    // sum_incl should be 0+1+2+...+10 = 55

    // --- Range with variables ---
    let start = 5;
    let end = 10;
    let mut count = 0;
    for i in start..end {
        count += 1;
    }
    // count should be 5

    // --- Inclusive range with variables ---
    let mut count_incl = 0;
    for i in start..=end {
        count_incl += 1;
    }
    // count_incl should be 6

    // --- Range of one element (exclusive) ---
    let mut single_count = 0;
    for i in 0..1 {
        single_count += 1;
    }
    // single_count = 1

    // --- Empty range (exclusive, start == end) ---
    let mut empty_count = 0;
    for i in 5..5 {
        empty_count += 1;
    }
    // empty_count = 0

    // --- Range of one element (inclusive) ---
    let mut single_incl = 0;
    for i in 5..=5 {
        single_incl += 1;
    }
    // single_incl = 1

    // --- Nested range loops ---
    let mut pairs = 0;
    for i in 0..3 {
        for j in 0..3 {
            pairs += 1;
        }
    }
    // pairs = 9

    // --- Range pattern in match (inclusive) ---
    let score = 85;
    let grade = match score {
        90..=100 => "A",
        80..=89 => "B",
        70..=79 => "C",
        60..=69 => "D",
        0..=59 => "F",
        _ => "invalid",
    };

    // --- Range pattern with char ---
    let ch = 'g';
    let category = match ch {
        'a'..='z' => "lowercase",
        'A'..='Z' => "uppercase",
        '0'..='9' => "digit",
        _ => "other",
    };

    // --- Range pattern with integers ---
    let code = 404;
    let status = match code {
        200..=299 => "success",
        300..=399 => "redirect",
        400..=499 => "client error",
        500..=599 => "server error",
        _ => "unknown",
    };

    // --- Range pattern combined with or-pattern ---
    let month = 6;
    let season = match month {
        3 | 4 | 5 => "spring",
        6 | 7 | 8 => "summer",
        9 | 10 | 11 => "autumn",
        12 | 1 | 2 => "winter",
        _ => "invalid",
    };

    // --- Negative range ---
    for i in -5..5 {
        let abs = if i >= 0 { i } else { -i };
    }
}
