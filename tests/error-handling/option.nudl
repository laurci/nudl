// Test: Option<T> type — Some(v), None, matching on options
// Option is a built-in enum: enum Option<T> { Some(T), None }

// Find first element matching a predicate
fn find_first_even(numbers: i32[]) -> Option<i32> {
    for n in numbers {
        if n % 2 == 0 {
            return Some(n);
        }
    }
    None
}

// Safe array access by index
fn get_at(items: string[], index: i32) -> Option<string> {
    if index >= 0 && index < items.len() as i32 {
        Some(items[index])
    } else {
        None
    }
}

// Find index of an element
fn index_of(items: i32[], target: i32) -> Option<i32> {
    for (i, item) in items.enumerate() {
        if item == target {
            return Some(i as i32);
        }
    }
    None
}

// Transform an optional value
fn double_if_present(opt: Option<i32>) -> Option<i32> {
    match opt {
        Some(v) => Some(v * 2),
        None => None,
    }
}

// Combine two options: return Some only if both are present
fn both_present(a: Option<i32>, b: Option<i32>) -> Option<(i32, i32)> {
    match (a, b) {
        (Some(x), Some(y)) => Some((x, y)),
        _ => None,
    }
}

fn main() {
    // --- Basic Some and None construction ---
    let some_val: Option<i32> = Some(42);
    let none_val: Option<i32> = None;

    // --- Pattern matching on Option ---
    let msg1 = match some_val {
        Some(v) => `found: {v}`,
        None => "nothing",
    };
    // msg1 == "found: 42"

    let msg2 = match none_val {
        Some(v) => `found: {v}`,
        None => "nothing",
    };
    // msg2 == "nothing"

    // --- if let with Option ---
    if let Some(value) = some_val {
        println(`Unwrapped: {value}`);
    }

    if let Some(_) = none_val {
        println("This should not print");
    } else {
        println("None branch taken");
    }

    // --- while let with Option (iterator-style) ---
    let mut items: i32[] = [10, 20, 30];
    let mut idx = 0;
    while let Some(item) = get_at_i32(items, idx) {
        println(`item[{idx}] = {item}`);
        idx += 1;
    }

    // --- find_first_even ---
    let evens = find_first_even([1, 3, 5, 7, 8, 10]);
    match evens {
        Some(n) => println(`First even: {n}`),     // 8
        None => println("No even numbers"),
    }

    let no_evens = find_first_even([1, 3, 5, 7]);
    match no_evens {
        Some(n) => println(`First even: {n}`),
        None => println("No even numbers found"),   // this branch
    }

    // --- Safe array access ---
    let names: string[] = ["alice", "bob", "charlie"];
    match get_at(names, 1) {
        Some(name) => println(`Found: {name}`),     // "bob"
        None => println("Index out of bounds"),
    }
    match get_at(names, 99) {
        Some(name) => println(`Found: {name}`),
        None => println("Index out of bounds"),      // this branch
    }

    // --- Nested Options ---
    let nested: Option<Option<i32>> = Some(Some(42));
    match nested {
        Some(Some(v)) => println(`Deeply nested: {v}`),
        Some(None) => println("Inner is None"),
        None => println("Outer is None"),
    }

    let nested_none: Option<Option<i32>> = Some(None);
    match nested_none {
        Some(Some(v)) => println(`Deeply nested: {v}`),
        Some(None) => println("Inner is None"),      // this branch
        None => println("Outer is None"),
    }

    // --- Option with different types ---
    let str_opt: Option<string> = Some("hello");
    let bool_opt: Option<bool> = None;
    let tuple_opt: Option<(i32, string)> = Some((1, "one"));

    match tuple_opt {
        Some((n, s)) => println(`tuple: ({n}, {s})`),
        None => println("no tuple"),
    }

    // --- Combining options ---
    let combined = both_present(Some(10), Some(20));
    match combined {
        Some((a, b)) => println(`Both: {a}, {b}`),
        None => println("At least one missing"),
    }

    let partial = both_present(Some(10), None);
    match partial {
        Some((a, b)) => println(`Both: {a}, {b}`),
        None => println("At least one missing"),    // this branch
    }

    // --- double_if_present ---
    let doubled = double_if_present(Some(21));
    match doubled {
        Some(v) => println(`Doubled: {v}`),        // 42
        None => println("Nothing to double"),
    }

    let no_double = double_if_present(None);
    match no_double {
        Some(v) => println(`Doubled: {v}`),
        None => println("Nothing to double"),       // this branch
    }

    // --- Option in a collection ---
    let options: Option<i32>[] = [Some(1), None, Some(3), None, Some(5)];
    for opt in options {
        match opt {
            Some(v) => println(`  value: {v}`),
            None => println("  absent"),
        }
    }
}

// Helper: get_at for i32 arrays (used by while let example)
fn get_at_i32(items: i32[], index: i32) -> Option<i32> {
    if index >= 0 && index < items.len() as i32 {
        Some(items[index])
    } else {
        None
    }
}
