// Test: panic("msg") terminates the program immediately
// panic has return type ! (never type) — it can be used in any expression context.

// panic in a function
fn assert_positive(n: i32) -> i32 {
    if n <= 0 {
        panic("expected a positive number");
    }
    n
}

// panic as an expression in match arms
fn unwrap_or_panic(opt: Option<i32>) -> i32 {
    match opt {
        Some(v) => v,
        None => panic("called unwrap on None"),
    }
}

// panic in an if-else expression (never type unifies with any type)
fn safe_index(items: i32[], index: i32) -> i32 {
    if index >= 0 && index < items.len() as i32 {
        items[index]
    } else {
        panic(f"index {index} out of bounds for length {items.len()}")
    }
}

// panic as an unreachable marker
fn direction_name(dx: i32, dy: i32) -> string {
    match (dx, dy) {
        (0, 1) => "north",
        (0, -1) => "south",
        (1, 0) => "east",
        (-1, 0) => "west",
        _ => panic(f"invalid direction: ({dx}, {dy})"),
    }
}

// panic in a let binding (never type allows this)
fn must_have_value(opt: Option<string>) -> string {
    let value = match opt {
        Some(v) => v,
        None => panic("value is required"),
    };
    value
}

// Using panic for unimplemented functionality
fn todo_feature() -> i32 {
    panic("not yet implemented");
}

fn main() {
    // --- Normal operation (no panic) ---
    let x = assert_positive(5);
    println(f"Positive: {x}");

    let y = unwrap_or_panic(Some(42));
    println(f"Unwrapped: {y}");

    let items: i32[] = [10, 20, 30];
    let val = safe_index(items, 1);
    println(f"Item at 1: {val}");

    let dir = direction_name(1, 0);
    println(f"Direction: {dir}");

    let name = must_have_value(Some("nudl"));
    println(f"Name: {name}");

    // --- This line would panic if uncommented ---
    // assert_positive(-1);
    // unwrap_or_panic(None);
    // safe_index(items, 99);
    // direction_name(2, 3);
    // must_have_value(None);
    // todo_feature();

    // panic terminates the program — the lines below this would not execute
    // panic("intentional panic for testing");
    // println("This line is never reached");

    println("All non-panic paths succeeded");
}
