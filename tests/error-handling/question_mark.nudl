// Test: ? operator for early return on Result and Option
// The ? operator propagates Err/None to the caller automatically.

// --- ? on Result ---

fn parse_number(input: string) -> Result<i32, string> {
    // Simulated parsing that may fail
    if input == "42" {
        Ok(42)
    } else if input == "0" {
        Ok(0)
    } else {
        Err(`cannot parse '{input}' as i32`)
    }
}

fn read_file(path: string) -> Result<string, string> {
    if path == "config.txt" {
        Ok("port=8080")
    } else {
        Err(`file not found: {path}`)
    }
}

// Chain multiple fallible operations with ?
fn get_port() -> Result<i32, string> {
    let content = read_file("config.txt")?;   // propagates Err if file not found
    let port_str = extract_value(content, "port")?;  // propagates Err if key missing
    let port = parse_number(port_str)?;        // propagates Err if parse fails
    Ok(port)
}

fn extract_value(content: string, key: string) -> Result<string, string> {
    // Simplified key=value parser
    if content == "port=8080" && key == "port" {
        Ok("8080")
    } else {
        Err(`key '{key}' not found in content`)
    }
}

// ? with early return in the middle of a function
fn process_two_numbers(a: string, b: string) -> Result<i32, string> {
    let x = parse_number(a)?;    // returns Err early if a is invalid
    let y = parse_number(b)?;    // returns Err early if b is invalid
    Ok(x + y)
}

// ? inside a loop
fn sum_all(inputs: string[]) -> Result<i32, string> {
    let mut total = 0;
    for input in inputs {
        let n = parse_number(input)?;  // early return on first bad input
        total += n;
    }
    Ok(total)
}

// --- ? on Option ---

fn find_user(name: string) -> Option<string> {
    if name == "alice" {
        Some("alice@example.com")
    } else if name == "bob" {
        Some("bob@example.com")
    } else {
        None
    }
}

fn find_domain(email: string) -> Option<string> {
    if email == "alice@example.com" {
        Some("example.com")
    } else {
        None
    }
}

// Chain optional lookups with ?
fn get_user_domain(name: string) -> Option<string> {
    let email = find_user(name)?;        // returns None if user not found
    let domain = find_domain(email)?;    // returns None if domain not found
    Some(domain)
}

// ? on Option inside a loop
fn find_all_emails(names: string[]) -> Option<string[]> {
    let mut emails: string[] = [];
    for name in names {
        let email = find_user(name)?;    // returns None on first missing user
        emails.push(email);
    }
    Some(emails)
}

// Mixing ? with regular control flow
fn safe_divide(a: f64, b: f64) -> Result<f64, string> {
    if b == 0.0 {
        return Err("division by zero");
    }
    Ok(a / b)
}

fn complex_calculation(a: f64, b: f64, c: f64) -> Result<f64, string> {
    let ab = safe_divide(a, b)?;
    let result = safe_divide(ab, c)?;
    if result < 0.0 {
        return Err("negative result");
    }
    Ok(result)
}

// --- map_err for error type conversion ---
// When ? is used and error types differ, map_err converts at the call site.

enum AppError {
    IoError(string),
    ParseError(string),
}

fn read_data(path: string) -> Result<string, string> {
    if path == "data.txt" {
        Ok("42")
    } else {
        Err(`file not found: {path}`)
    }
}

fn parse_i32(s: string) -> Result<i32, string> {
    if s == "42" {
        Ok(42)
    } else {
        Err(`invalid number: {s}`)
    }
}

fn load_number(path: string) -> Result<i32, AppError> {
    let content = read_data(path).map_err(AppError::IoError)?;
    let number = parse_i32(content).map_err(AppError::ParseError)?;
    Ok(number)
}

fn main() {
    // --- ? on Result: success path ---
    match process_two_numbers("42", "0") {
        Ok(sum) => println(`Sum: {sum}`),           // Sum: 42
        Err(e) => println(`Error: {e}`),
    }

    // --- ? on Result: first argument fails ---
    match process_two_numbers("bad", "42") {
        Ok(sum) => println(`Sum: {sum}`),
        Err(e) => println(`Error: {e}`),           // Error: cannot parse 'bad'
    }

    // --- ? on Result: second argument fails ---
    match process_two_numbers("42", "bad") {
        Ok(sum) => println(`Sum: {sum}`),
        Err(e) => println(`Error: {e}`),           // Error: cannot parse 'bad'
    }

    // --- Chained ? calls ---
    match get_port() {
        Ok(port) => println(`Port: {port}`),
        Err(e) => println(`Error: {e}`),
    }

    // --- ? in a loop ---
    match sum_all(["42", "0", "42"]) {
        Ok(total) => println(`Total: {total}`),     // Total: 84
        Err(e) => println(`Error: {e}`),
    }

    match sum_all(["42", "bad", "0"]) {
        Ok(total) => println(`Total: {total}`),
        Err(e) => println(`Error: {e}`),           // Error on "bad"
    }

    // --- ? on Option: success path ---
    match get_user_domain("alice") {
        Some(domain) => println(`Domain: {domain}`),   // example.com
        None => println("Not found"),
    }

    // --- ? on Option: user not found ---
    match get_user_domain("charlie") {
        Some(domain) => println(`Domain: {domain}`),
        None => println("Not found"),               // charlie doesn't exist
    }

    // --- ? on Option in a loop ---
    match find_all_emails(["alice", "bob"]) {
        Some(emails) => {
            for email in emails {
                println(`  email: {email}`);
            }
        },
        None => println("Some users not found"),
    }

    match find_all_emails(["alice", "charlie", "bob"]) {
        Some(emails) => println("All found"),
        None => println("Some users not found"),     // charlie missing
    }

    // --- Complex calculation with ? ---
    match complex_calculation(100.0, 5.0, 2.0) {
        Ok(v) => println(`Result: {v}`),            // 10.0
        Err(e) => println(`Error: {e}`),
    }

    match complex_calculation(100.0, 0.0, 2.0) {
        Ok(v) => println(`Result: {v}`),
        Err(e) => println(`Error: {e}`),           // division by zero
    }

    // --- map_err for error type conversion ---
    match load_number("data.txt") {
        Ok(n) => println(`Loaded number: {n}`),     // 42
        Err(AppError::IoError(e)) => println(`IO error: {e}`),
        Err(AppError::ParseError(e)) => println(`Parse error: {e}`),
    }

    match load_number("missing.txt") {
        Ok(n) => println(`Loaded: {n}`),
        Err(AppError::IoError(e)) => println(`IO error: {e}`),   // file not found
        Err(AppError::ParseError(e)) => println(`Parse error: {e}`),
    }
}
