// Test: Format string literals — f"..."
// Covers: interpolation {expr}, escaped braces {{ }}, nested f-strings,
//         expressions inside interpolation, Printable interface

fn add(a: i32, b: i32) -> i32 {
    a + b
}

fn main() {
    // --- Basic interpolation ---
    let name = "world";
    let greeting = f"hello, {name}";

    // --- Interpolation with expressions ---
    let sum = f"1 + 1 = {1 + 1}";
    let product = f"3 * 4 = {3 * 4}";

    // --- Escaped braces ---
    let literal_braces = f"braces: {{ and }}";
    let mixed = f"value: {42}, literal: {{not interpolated}}";

    // --- Nested format strings ---
    let inner = f"nested: {f"inner {42}"}";
    let deep = f"a {f"b {f"c"}"}";

    // --- Variable interpolation ---
    let x = 10;
    let y = 20;
    let coords = f"({x}, {y})";

    // --- Function call in interpolation ---
    let result = f"sum is {add(3, b: 4)}";

    // --- Multiple interpolations ---
    let a = "first";
    let b = "second";
    let c = "third";
    let all = f"{a}, {b}, and {c}";

    // --- Interpolation with boolean ---
    let flag = true;
    let bool_str = f"flag is {flag}";

    // --- Interpolation with numeric types ---
    let int_val: i32 = 42;
    let float_val: f64 = 3.14;
    let formatted = f"int={int_val}, float={float_val}";

    // --- Complex expressions ---
    let conditional = f"sign: {if x > 0 { "positive" } else { "non-positive" }}";
    let arithmetic = f"result: {(x + y) * 2}";

    // --- Empty interpolation body (just a variable) ---
    let msg = "ok";
    let wrapped = f"[{msg}]";

    // --- Adjacent interpolations ---
    let first = "abc";
    let second = "def";
    let adjacent = f"{first}{second}";

    // --- Format string with no interpolation (still valid, just a string) ---
    let plain = f"no interpolation here";

    // --- Format string with escape sequences ---
    let with_escapes = f"tab:\there, newline:\n{name}";

    // --- Interpolation at start and end ---
    let at_start = f"{name} is here";
    let at_end = f"hello {name}";
    let both = f"{name}{name}";
}
