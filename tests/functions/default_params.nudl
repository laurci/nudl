//! mode: check
//! expect: pass
// Test: Default parameters (param: Type = default_value).
//       Ordering rule: required -> default -> optional.
//       Default expressions are evaluated at the call site when omitted.

// Function with one default parameter
fn repeat_string(s: string, times: i32 = 3) -> i32 {
    times
}

// Multiple defaults
fn format_number(value: i32, precision: i32 = 2, prefix: string = "", suffix: string = "") -> i32 {
    value + precision
}

// Mix of required and default parameters
fn create_user(name: string, age: i32, role: string = "user", active: bool = true) -> string {
    name
}

// All-default after first required
fn connect(host: string, port: i32 = 8080, timeout_ms: i32 = 30000) -> i32 {
    port
}

fn main() {
    // Use default for 'times'
    let a = repeat_string("hello");

    // Override the default
    let b = repeat_string("world", times: 5);

    // Use all defaults
    let c = format_number(42);

    // Override some defaults
    let d = format_number(42, precision: 4);

    // Mix of required and default
    let f = create_user("Alice", age: 30);
    let g = create_user("Bob", age: 25, role: "admin");

    // Connect with defaults
    let i = connect("localhost");
    let j = connect("localhost", port: 9090);
    let k = connect("localhost", port: 9090, timeout_ms: 5000);
}
