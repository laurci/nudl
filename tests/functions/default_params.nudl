// Test: Default parameters (param: Type = default_value).
//       Ordering rule: required -> default -> optional.
//       Default expressions are evaluated at the call site when omitted.

// Function with one default parameter
fn repeat_string(s: string, times: i32 = 3) -> string {
    let mut result = "";
    for _ in 0..times {
        result = f"{result}{s}";
    }
    result
}

// Function with multiple default parameters
fn format_number(value: f64, precision: i32 = 2, prefix: string = "", suffix: string = "") -> string {
    f"{prefix}{value}{suffix}"
}

// Required params before defaults (ordering rule)
fn create_user(name: string, age: i32, role: string = "user", active: bool = true) -> string {
    f"User({name}, age: {age}, role: {role}, active: {active})"
}

// Default parameter using a constant expression
fn connect(host: string, port: u16 = 8080, timeout_ms: u64 = 30000) -> string {
    f"connecting to {host}:{port} (timeout: {timeout_ms}ms)"
}

// All parameters have defaults except the first
fn log_message(msg: string, level: string = "INFO", timestamp: string = "now") -> string {
    f"[{timestamp}] [{level}] {msg}"
}

// Default value is a computed expression
fn make_buffer(size: i32 = 1024) -> i32 {
    size
}

fn main() {
    // Call with all arguments provided
    let s1 = repeat_string("ha", times: 5);
    println(f"repeat 5: {s1}");

    // Call omitting the default parameter
    let s2 = repeat_string("ho");
    println(f"repeat default(3): {s2}");

    // Multiple defaults: provide all
    let n1 = format_number(3.14, precision: 4, prefix: "$", suffix: "!");
    println(n1);

    // Multiple defaults: omit all defaults
    let n2 = format_number(42.0);
    println(n2);

    // Multiple defaults: provide some, omit others
    let n3 = format_number(99.9, prefix: "> ");
    println(n3);

    // Required before defaults
    let u1 = create_user("Alice", age: 30);
    println(u1);

    let u2 = create_user("Bob", age: 25, role: "admin", active: false);
    println(u2);

    // Partial override of defaults
    let u3 = create_user("Charlie", age: 40, role: "moderator");
    println(u3);

    // Connection with defaults
    let c1 = connect("localhost");
    println(c1);

    let c2 = connect("prod.example.com", port: 443, timeout_ms: 5000);
    println(c2);

    // Log with defaults
    let l1 = log_message("server started");
    println(l1);

    let l2 = log_message("disk full", level: "ERROR");
    println(l2);

    // Buffer with default
    let b1 = make_buffer();
    println(f"buffer size: {b1}");

    let b2 = make_buffer(4096);
    println(f"buffer size: {b2}");
}
