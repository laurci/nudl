// Test: Basic function declarations, parameters, return types,
//       implicit return (tail expression), and explicit return.

// Simple function with explicit return type and implicit return (tail expr)
fn add(a: i32, b: i32) -> i32 {
    a + b
}

// Function with no return type (returns unit ())
fn greet(name: string) {
    println(f"Hello, {name}!");
}

// Function with explicit return statement for early exit
fn abs_value(x: i32) -> i32 {
    if x < 0 {
        return -x;
    }
    x
}

// Function returning unit explicitly via empty body
fn do_nothing() {
}

// Multiple parameters of different types
fn format_entry(index: i32, label: string, value: f64) -> string {
    f"[{index}] {label}: {value}"
}

// Function with block body using intermediate bindings and tail expression
fn hypotenuse(a: f64, b: f64) -> f64 {
    let a_sq = a * a;
    let b_sq = b * b;
    (a_sq + b_sq).sqrt()
}

// Nested function definitions (item statements inside blocks)
fn outer() -> i32 {
    fn inner(x: i32) -> i32 {
        x * 2
    }
    inner(21)
}

// Function with multiple early returns
fn classify(n: i32) -> string {
    if n < 0 {
        return "negative";
    }
    if n == 0 {
        return "zero";
    }
    if n > 100 {
        return "large positive";
    }
    "positive"
}

// Implicit return from if/else expression (tail expression)
fn max(a: i32, b: i32) -> i32 {
    if a >= b { a } else { b }
}

// Function returning a boolean
fn is_even(n: i32) -> bool {
    n % 2 == 0
}

fn main() {
    // Test basic calls
    let sum = add(1, b: 2);
    println(f"add(1, 2) = {sum}");

    // Test unit-returning function
    greet("world");

    // Test explicit return
    let abs_neg = abs_value(-42);
    let abs_pos = abs_value(42);
    println(f"abs(-42) = {abs_neg}, abs(42) = {abs_pos}");

    // Test do_nothing
    do_nothing();

    // Test multi-param function
    let entry = format_entry(0, label: "pi", value: 3.14);
    println(entry);

    // Test block body with tail expression
    let h = hypotenuse(3.0, b: 4.0);
    println(f"hypotenuse(3, 4) = {h}");

    // Test nested function
    let result = outer();
    println(f"outer() = {result}");

    // Test multiple early returns
    println(f"classify(-5) = {classify(-5)}");
    println(f"classify(0) = {classify(0)}");
    println(f"classify(50) = {classify(50)}");
    println(f"classify(200) = {classify(200)}");

    // Test implicit return from if/else
    let m = max(10, b: 20);
    println(f"max(10, 20) = {m}");

    // Test boolean return
    println(f"is_even(4) = {is_even(4)}");
    println(f"is_even(7) = {is_even(7)}");
}
