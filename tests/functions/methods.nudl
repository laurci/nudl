//! mode: check
//! expect: pass
// Test: Methods via impl blocks.
//       - self (immutable receiver)
//       - mut self (mutable receiver)
//       - Static methods (no self parameter)
//       - Multiple impl blocks for the same type

struct Point {
    x: i32,
    y: i32,
}

impl Point {
    // Static method (no self parameter) — used as a constructor
    fn new(x: i32, y: i32) -> Point {
        Point { x: x, y: y }
    }

    // Immutable method (self parameter)
    fn sum(self) -> i32 {
        self.x + self.y
    }

    // Mutable method (mut self)
    fn translate(mut self, dx: i32, dy: i32) {
        self.x = self.x + dx;
        self.y = self.y + dy;
    }

    // Method that returns a new Point
    fn offset(self, dx: i32, dy: i32) -> Point {
        Point { x: self.x + dx, y: self.y + dy }
    }
}

// Second impl block for the same type
impl Point {
    fn scale(mut self, factor: i32) {
        self.x = self.x * factor;
        self.y = self.y * factor;
    }
}

struct Counter {
    value: i32,
}

impl Counter {
    fn new(start: i32) -> Counter {
        Counter { value: start }
    }

    fn get(self) -> i32 {
        self.value
    }

    fn increment(mut self) {
        self.value = self.value + 1;
    }

    fn add(mut self, n: i32) {
        self.value = self.value + n;
    }
}

struct Rectangle {
    width: i32,
    height: i32,
}

impl Rectangle {
    fn new(width: i32, height: i32) -> Rectangle {
        Rectangle { width: width, height: height }
    }

    fn area(self) -> i32 {
        self.width * self.height
    }

    fn perimeter(self) -> i32 {
        2 * (self.width + self.height)
    }

    // Static method: construct a square
    fn square(side: i32) -> Rectangle {
        Rectangle { width: side, height: side }
    }

    fn scale(mut self, factor: i32) {
        self.width = self.width * factor;
        self.height = self.height * factor;
    }
}

fn main() {
    // Static method calls
    let p1 = Point::new(3, y: 4);
    let p2 = Point::new(1, y: 2);

    // Immutable method calls
    let s = p1.sum();

    // Method with args
    let p3 = p1.offset(10, dy: 20);

    // Mutable method calls
    let mut p4 = Point::new(0, y: 0);
    p4.translate(5, dy: 10);
    p4.scale(3);

    // Counter
    let mut c = Counter::new(0);
    c.increment();
    c.increment();
    c.add(10);
    let v = c.get();

    // Rectangle
    let rect = Rectangle::new(10, height: 20);
    let a = rect.area();
    let p = rect.perimeter();

    // Static method
    let sq = Rectangle::square(5);

    // Mutable method
    let mut r2 = Rectangle::new(3, height: 4);
    r2.scale(2);
}
