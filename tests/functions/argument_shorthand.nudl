//! mode: check
//! expect: pass
// Test: Argument shorthand — when a variable at the call site has the same
//       name as a named parameter, the caller may write just the variable name
//       instead of `name: name`.

fn create_point(x: i32, y: i32) -> i32 {
    x + y
}

fn send_request(url: string, method: string, body: string) -> string {
    url
}

fn make_config(host: string, port: i32, tls: bool = false) -> i32 {
    port
}

struct Color {
    r: i32,
    g: i32,
    b: i32,
}

fn main() {
    // Shorthand: variable 'y' matches param 'y'
    let y = 20;
    let p = create_point(10, y);

    // Multiple shorthand arguments
    let method = "GET";
    let body = "none";
    let r = send_request("https://example.com", method, body);

    // Shorthand with default params
    let host = "localhost";
    let port = 9090;
    let c = make_config(host, port);

    // Struct field shorthand
    let r = 255;
    let g = 128;
    let b = 0;
    let orange = Color { r, g, b };
}
